# =============================================================================
# MODEL PROVIDER
# =============================================================================
# Choose: anthropic | openai | google | ollama | minimax
MODEL_PROVIDER=minimax

# Anthropic (Claude) - Current default
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (GPT) - Uncomment to use
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Google (Gemini) - Uncomment to use
# GOOGLE_API_KEY=AIza...
# GOOGLE_MODEL=gemini-1.5-pro

# Ollama (Local) - Uncomment to use (no API key needed)
# OLLAMA_MODEL=llama3.1
# OLLAMA_BASE_URL=http://localhost:11434

# Minimax (Anthropic-compatible API)
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_MODEL=MiniMax-M2.7

# =============================================================================
# TESTING
# =============================================================================
TEST_MODE=true
TEST_TELEGRAM_ID=123

# =============================================================================
# TELEGRAM
# =============================================================================
TELEGRAM_BOT_TOKEN=your-bot-token-here

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/health_agent
# For LangGraph checkpointer (uses psycopg, not asyncpg)
CHECKPOINTER_DB_URL=postgresql://postgres:postgres@localhost:5432/health_agent

# =============================================================================
# VECTOR STORE
# =============================================================================
QDRANT_URL=http://localhost:6333

# =============================================================================
# EVALUATION (LangSmith + DeepEval)
# =============================================================================
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT="H-agent_eval"
